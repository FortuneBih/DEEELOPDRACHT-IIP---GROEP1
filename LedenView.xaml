<Page x:Class="BubbelvriendWPF.Views.LedenView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F4F8">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- LINKS: Overzicht + acties -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titel -->
            <TextBlock Grid.Row="0" Text="Ledenoverzicht"
                       FontSize="20" FontWeight="Bold" Foreground="#1A237E"
                       Margin="0,0,0,12"/>

            <!-- Zoekbalk + filteropties -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#ECEFF1" BorderThickness="1"
                    Padding="12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label Content="Zoeken" Margin="0"/>
                        <TextBox x:Name="TxtZoeken"
                                 TextChanged="TxtZoeken_TextChanged"
                                 Text=""
                                 Margin="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0">
                        <Label Content="Filter op sterren" Margin="0"/>
                        <ComboBox x:Name="CmbFilterSterren"
                                  SelectionChanged="CmbFilterSterren_SelectionChanged"
                                  Width="130">
                            <ComboBoxItem Content="Alle niveaus" IsSelected="True"/>
                            <ComboBoxItem Content="★☆☆☆☆  (1 ster)"/>
                            <ComboBoxItem Content="★★☆☆☆  (2 sterren)"/>
                            <ComboBoxItem Content="★★★☆☆  (3 sterren)"/>
                            <ComboBoxItem Content="★★★★☆  (4 sterren)"/>
                            <ComboBoxItem Content="★★★★★  (5 sterren)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <TextBlock x:Name="TxtAantalLeden" FontSize="12"
                                   Foreground="#546E7A" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DataGrid leden -->
            <DataGrid Grid.Row="2" x:Name="DgLeden"
                      SelectionChanged="DgLeden_SelectionChanged"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Naam" Binding="{Binding Naam}" Width="110"/>
                    <DataGridTextColumn Header="Voornaam" Binding="{Binding Voornaam}" Width="110"/>
                    <DataGridTextColumn Header="Gemeente" Binding="{Binding Gemeente}" Width="110"/>
                    <DataGridTextColumn Header="Niveau" Binding="{Binding SterrenWeergave}" Width="100"/>
                    <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="*"/>
                    <DataGridTextColumn Header="Telefoon" Binding="{Binding Telefoonnummer}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Onderste knoppen: import/export -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="📥 Importeren (CSV)" Click="BtnImporteer_Click"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="📤 Exporteren (CSV)" Click="BtnExporteer_Click"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Grid>

        <!-- RECHTS: Formulier voor toevoegen/wijzigen -->
        <Border Grid.Column="1" Background="White" CornerRadius="10"
                BorderBrush="#ECEFF1" BorderThickness="1" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="TxtFormulierTitel"
                               Text="Nieuw lid toevoegen"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#1A237E" Margin="0,0,0,16"/>

                    <Label Content="Naam *"/>
                    <TextBox x:Name="TxtNaam" Margin="0,0,0,10"/>

                    <Label Content="Voornaam *"/>
                    <TextBox x:Name="TxtVoornaam" Margin="0,0,0,10"/>

                    <Label Content="Rijksregisternummer * (11 cijfers)"/>
                    <TextBox x:Name="TxtRijksreg" Margin="0,0,0,10" MaxLength="11"/>

                    <Label Content="Straat *"/>
                    <TextBox x:Name="TxtStraat" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Gemeente *" Margin="0"/>
                            <TextBox x:Name="TxtGemeente"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Label Content="Postcode *" Margin="0"/>
                            <TextBox x:Name="TxtPostcode" MaxLength="4"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Telefoonnummer *"/>
                    <TextBox x:Name="TxtTelefoon" Margin="0,0,0,10"/>

                    <Label Content="E-mailadres *"/>
                    <TextBox x:Name="TxtEmail" Margin="0,0,0,10"/>

                    <Label Content="Huisnummer *"/>
                    <TextBox x:Name="TxtHuisnummer" Margin="0,0,0,10"/>

                    <Label Content="Duikcertificaat (sterren) *"/>
                    <ComboBox x:Name="CmbSterren" Margin="0,0,0,20">
                        <ComboBoxItem Content="★☆☆☆☆  1 ster – Beginner"/>
                        <ComboBoxItem Content="★★☆☆☆  2 sterren"/>
                        <ComboBoxItem Content="★★★☆☆  3 sterren"/>
                        <ComboBoxItem Content="★★★★☆  4 sterren"/>
                        <ComboBoxItem Content="★★★★★  5 sterren – Expert"/>
                    </ComboBox>

                    <!-- Actie-knoppen -->
                    <Button x:Name="BtnOpslaan" Content="💾 Opslaan"
                            Click="BtnOpslaan_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,0,8"/>

                    <Button x:Name="BtnWijzigen" Content="✏️ Wijzigen geselecteerde"
                            Click="BtnWijzigen_Click"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,8" IsEnabled="False"/>

                    <Button x:Name="BtnVerwijderen" Content="🗑️ Verwijderen"
                            Click="BtnVerwijderen_Click"
                            Style="{StaticResource DangerButton}"
                            Margin="0,0,0,8" IsEnabled="False"/>

                    <Button Content="↺ Formulier leegmaken"
                            Click="BtnLeegmaken_Click"
                            Style="{StaticResource SecondaryButton}"/>

                    <!-- Foutmelding -->
                    <Border x:Name="FoutPanel" Background="#FFEBEE" CornerRadius="6"
                            BorderBrush="#EF9A9A" BorderThickness="1"
                            Padding="10" Margin="0,12,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="TxtFout" Foreground="#C62828"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
