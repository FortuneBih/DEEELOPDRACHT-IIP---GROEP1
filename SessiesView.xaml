<Page x:Class="BubbelvriendWPF.Views.SessiesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F4F8">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- LINKS: Overzicht bestaande sessies -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Trainingssessies – Overzicht"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#1A237E" Margin="0,0,0,12"/>

            <DataGrid Grid.Row="1" x:Name="DgSessies"
                      VerticalScrollBarVisibility="Auto"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Training"  Binding="{Binding Training.Naam}"      Width="160"/>
                    <DataGridTextColumn Header="Datum"     Binding="{Binding Training.DatumWeergave}" Width="90"/>
                    <DataGridTextColumn Header="Duiker 1"  Binding="{Binding Duiker1.VolledigeNaam}" Width="150"/>
                    <DataGridTextColumn Header="Duiker 2"  Binding="{Binding Duiker2.VolledigeNaam}" Width="150"/>
                    <DataGridTextColumn Header="Totaal ★"  Binding="{Binding TotaalSterren}"      Width="70"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Grid>

        <!-- RECHTS: Koppelingsformulier -->
        <Border Grid.Column="1" Background="White" CornerRadius="10"
                BorderBrush="#ECEFF1" BorderThickness="1" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Duo koppelen aan training"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#1A237E" Margin="0,0,0,16"/>

                    <!-- Stap 1: selecteer training -->
                    <Border Background="#E3F2FD" CornerRadius="6"
                            Padding="10" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Stap 1: Kies een training"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1565C0" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbTraining"
                                      SelectionChanged="CmbTraining_SelectionChanged"
                                      DisplayMemberPath="Naam"/>

                            <!-- Details van gekozen training -->
                            <Border x:Name="TrainingDetailsPanel"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="TxtTrainingDetails"
                                               FontSize="12" Foreground="#546E7A"
                                               TextWrapping="Wrap"/>
                                    <Border x:Name="VolPanel" Background="#FFEBEE"
                                            CornerRadius="4" Padding="8,4"
                                            Margin="0,4,0,0" Visibility="Collapsed">
                                        <TextBlock Text="⚠️ Deze training is VOL"
                                                   Foreground="#C62828"
                                                   FontWeight="SemiBold" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Stap 2: selecteer duiker 1 -->
                    <Border Background="#E8F5E9" CornerRadius="6"
                            Padding="10" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Stap 2 – Kies Duiker 1"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#2E7D32" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbDuiker1"
                                      SelectionChanged="CmbDuiker_SelectionChanged"
                                      DisplayMemberPath="VolledigeNaam"/>
                            <TextBlock x:Name="TxtDuiker1Sterren"
                                       FontSize="12" Foreground="#2E7D32"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Stap 3: selecteer duiker 2 -->
                    <Border Background="#E8F5E9" CornerRadius="6"
                            Padding="10" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Stap 3 – Kies Duiker 2"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#2E7D32" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbDuiker2"
                                      SelectionChanged="CmbDuiker_SelectionChanged"
                                      DisplayMemberPath="VolledigeNaam"/>
                            <TextBlock x:Name="TxtDuiker2Sterren"
                                       FontSize="12" Foreground="#2E7D32"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Sterren-preview -->
                    <Border x:Name="SterrenPreview" Background="#F3E5F5"
                            CornerRadius="6" Padding="12" Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Team-preview"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#6A1B9A" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtSterrenPreview"
                                       FontSize="14" Foreground="#4A148C"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TxtGeldigheidPreview"
                                       FontSize="12" Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Button Content="🔗 Duo koppelen aan training"
                            Click="BtnKoppelen_Click"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,0,8"/>

                    <Button Content="↺ Reset"
                            Click="BtnReset_Click"
                            Style="{StaticResource SecondaryButton}"/>

                    <!-- Foutpanel -->
                    <Border x:Name="FoutPanel" Background="#FFEBEE"
                            CornerRadius="6" BorderBrush="#EF9A9A"
                            BorderThickness="1" Padding="10"
                            Margin="0,12,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="TxtFout" Foreground="#C62828"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
