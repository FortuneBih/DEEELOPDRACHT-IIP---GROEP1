<Window x:Class="Bubbelvrienden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bubbelvrienden"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Tab styling -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- DataGrid styling -->
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F0F4F8"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
        </Style>

        <!-- TextBlock label styling -->
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <!-- Button styling -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#1F6AA5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- TextBox styling -->
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="28"/>
        </Style>

        <!-- ComboBox styling -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <TabControl x:Name="tabMain" FontSize="14">

            <!-- TAB: LEDEN -->
            <TabItem Header="Leden">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Leden beheren"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                Padding="15"
                                BorderBrush="LightGray"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Lid toevoegen of wijzigen"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,15"/>

                                    <TextBlock Text="Naam"/>
                                    <TextBox x:Name="txtNaam" Margin="0,5,0,10"/>

                                    <TextBlock Text="Voornaam"/>
                                    <TextBox x:Name="txtVoornaam" Margin="0,5,0,10"/>

                                    <TextBlock Text="Rijksregisternummer"/>
                                    <TextBox x:Name="txtRijksregister" Margin="0,5,0,10"/>

                                    <TextBlock Text="Straat"/>
                                    <TextBox x:Name="txtStraat" Margin="0,5,0,10"/>

                                    <TextBlock Text="Huisnummer"/>
                                    <TextBox x:Name="txtHuisnummer" Margin="0,5,0,10"/>

                                    <TextBlock Text="Postcode"/>
                                    <TextBox x:Name="txtPostcode" Margin="0,5,0,10"/>

                                    <TextBlock Text="Gemeente"/>
                                    <TextBox x:Name="txtGemeente" Margin="0,5,0,10"/>

                                    <TextBlock Text="Telefoonnummer"/>
                                    <TextBox x:Name="txtTelefoon" Margin="0,5,0,10"/>

                                    <TextBlock Text="Email"/>
                                    <TextBox x:Name="txtEmail" Margin="0,5,0,10"/>

                                    <TextBlock Text="Aantal sterren"/>
                                    <ComboBox x:Name="cmbSterren" Margin="0,5,0,15">
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="3"/>
                                        <ComboBoxItem Content="4"/>
                                        <ComboBoxItem Content="5"/>
                                    </ComboBox>

                                    <WrapPanel>
                                        <Button x:Name="btnToevoegen"
                                                Content="Toevoegen"
                                                Width="100"
                                                Margin="0,0,10,0"
                                                Click="btnToevoegen_Click"/>
                                        <Button x:Name="btnWijzigen"
                                                Content="Wijzigen"
                                                Width="100"
                                                Margin="0,0,10,0"
                                                Click="btnWijzigen_Click"/>
                                        <Button x:Name="btnVerwijderen"
                                                Content="Verwijderen"
                                                Width="100"
                                                Click="btnVerwijderen_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                Padding="15"
                                BorderBrush="LightGray"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Zoeken:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox x:Name="txtZoekenLeden"
                                             Width="200"
                                             Margin="0,0,10,0"/>
                                    <Button x:Name="btnZoekenLeden"
                                            Content="Zoeken"
                                            Width="90"
                                            Margin="0,0,10,0"
                                            Click="btnZoekenLeden_Click"/>
                                    <Button x:Name="btnResetLeden"
                                            Content="Reset"
                                            Width="90"
                                            Click="btnResetLeden_Click"/>
                                </StackPanel>

                                <DataGrid x:Name="dgLeden"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Margin="0,0,0,15">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Naam" Binding="{Binding Naam}" Width="*"/>
                                        <DataGridTextColumn Header="Voornaam" Binding="{Binding Voornaam}" Width="*"/>
                                        <DataGridTextColumn Header="Rijksregisternummer" Binding="{Binding Rijksregisternummer}" Width="*"/>
                                        <DataGridTextColumn Header="Gemeente" Binding="{Binding Gemeente}" Width="*"/>
                                        <DataGridTextColumn Header="Telefoon" Binding="{Binding Telefoon}" Width="*"/>
                                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                                        <DataGridTextColumn Header="Sterren" Binding="{Binding Sterren}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <WrapPanel Grid.Row="2">
                                    <Button x:Name="btnSterVerhogen"
                                            Content="Ster verhogen"
                                            Width="120"
                                            Margin="0,0,10,0"
                                            Click="btnSterVerhogen_Click"/>
                                    <Button x:Name="btnLeegmaken"
                                            Content="Velden leegmaken"
                                            Width="140"
                                            Click="btnLeegmaken_Click"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB: TRAININGEN -->
            <TabItem Header="Trainingen">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Trainingen beheren"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                Padding="15"
                                BorderBrush="LightGray"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Training toevoegen of wijzigen"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="0,0,0,15"/>

                                    <TextBlock Text="Naam van de training"/>
                                    <TextBox x:Name="txtTrainingNaam" Margin="0,5,0,10"/>

                                    <TextBlock Text="Titel"/>
                                    <TextBox x:Name="txtTrainingTitel" Margin="0,5,0,10"/>

                                    <TextBlock Text="Tags"/>
                                    <TextBox x:Name="txtTags" Margin="0,5,0,10"/>

                                    <TextBlock Text="Inhoud"/>
                                    <TextBox x:Name="txtInhoud"
                                             Margin="0,5,0,10"
                                             Height="80"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>

                                    <TextBlock Text="Stad"/>
                                    <TextBox x:Name="txtStad" Margin="0,5,0,10"/>

                                    <TextBlock Text="Provincie"/>
                                    <TextBox x:Name="txtProvincie" Margin="0,5,0,10"/>

                                    <TextBlock Text="Aantal beschikbare plaatsen"/>
                                    <TextBox x:Name="txtAantalPlaatsen" Margin="0,5,0,10"/>

                                    <TextBlock Text="Niveau"/>
                                    <ComboBox x:Name="cmbNiveau" Margin="0,5,0,10">
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="3"/>
                                        <ComboBoxItem Content="4"/>
                                        <ComboBoxItem Content="5"/>
                                    </ComboBox>

                                    <TextBlock Text="Diepte (meter)"/>
                                    <TextBox x:Name="txtDiepte" Margin="0,5,0,10"/>

                                    <TextBlock Text="Datum"/>
                                    <DatePicker x:Name="dpDatum" Margin="0,5,0,10"/>

                                    <TextBlock Text="Startuur"/>
                                    <TextBox x:Name="txtStartuur" Margin="0,5,0,10"/>

                                    <TextBlock Text="Einduur"/>
                                    <TextBox x:Name="txtEinduur" Margin="0,5,0,15"/>

                                    <WrapPanel>
                                        <Button x:Name="btnTrainingToevoegen"
                                                Content="Toevoegen"
                                                Width="100"
                                                Margin="0,0,10,0"
                                                Click="btnTrainingToevoegen_Click"/>
                                        <Button x:Name="btnTrainingWijzigen"
                                                Content="Wijzigen"
                                                Width="100"
                                                Margin="0,0,10,0"
                                                Click="btnTrainingWijzigen_Click"/>
                                        <Button x:Name="btnTrainingVerwijderen"
                                                Content="Verwijderen"
                                                Width="100"
                                                Click="btnTrainingVerwijderen_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                Padding="15"
                                BorderBrush="LightGray"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Text="Zoeken:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBox x:Name="txtZoekenTrainingen"
                                             Width="200"
                                             Margin="0,0,10,0"/>
                                    <Button x:Name="btnZoekenTrainingen"
                                            Content="Zoeken"
                                            Width="90"
                                            Margin="0,0,10,0"
                                            Click="btnZoekenTrainingen_Click"/>
                                    <Button x:Name="btnResetTrainingen"
                                            Content="Reset"
                                            Width="90"
                                            Click="btnResetTrainingen_Click"/>
                                </StackPanel>

                                <DataGrid x:Name="dgTrainingen"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Margin="0,0,0,15">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Naam" Binding="{Binding Naam}" Width="*"/>
                                        <DataGridTextColumn Header="Titel" Binding="{Binding Titel}" Width="*"/>
                                        <DataGridTextColumn Header="Plaats" Binding="{Binding Plaats}" Width="*"/>
                                        <DataGridTextColumn Header="Niveau" Binding="{Binding Niveau}" Width="80"/>
                                        <DataGridTextColumn Header="Diepte" Binding="{Binding Diepte}" Width="80"/>
                                        <DataGridTextColumn Header="Datum" Binding="{Binding Datum}" Width="120"/>
                                        <DataGridTextColumn Header="Plaatsen" Binding="{Binding AantalPlaatsen}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <WrapPanel Grid.Row="2">
                                    <Button x:Name="btnVolStatus"
                                            Content="Status tonen"
                                            Width="120"
                                            Margin="0,0,10,0"
                                            Click="btnVolStatus_Click"/>
                                    <Button x:Name="btnTrainingLeegmaken"
                                            Content="Velden leegmaken"
                                            Width="140"
                                            Click="btnTrainingLeegmaken_Click"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB: TRAININGSSESSIES -->
            <TabItem Header="Trainingssessies">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Trainingssessies beheren"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Border Grid.Row="1"
                            Background="White"
                            Padding="15"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Selecteer training"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <ComboBox x:Name="cmbTrainingSessie" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Selecteer duiker 1"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <ComboBox x:Name="cmbDuiker1" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Selecteer duiker 2"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <ComboBox x:Name="cmbDuiker2" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="White"
                            Padding="15"
                            BorderBrush="LightGray"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Overzicht van trainingssessies"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <WrapPanel Grid.Row="1" Margin="0,0,0,15">
                                <Button x:Name="btnSessieMaken"
                                        Content="Sessie maken"
                                        Width="120"
                                        Margin="0,0,10,0"
                                        Click="btnSessieMaken_Click"/>
                                <Button x:Name="btnSessieVerwijderen"
                                        Content="Sessie verwijderen"
                                        Width="140"
                                        Margin="0,0,10,0"
                                        Click="btnSessieVerwijderen_Click"/>
                                <Button x:Name="btnControleerVoorwaarden"
                                        Content="Controle"
                                        Width="100"
                                        Click="btnControleerVoorwaarden_Click"/>
                            </WrapPanel>

                            <DataGrid x:Name="dgTrainingssessies"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      Margin="0,0,0,15">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Training" Binding="{Binding Training}" Width="*"/>
                                    <DataGridTextColumn Header="Duiker 1" Binding="{Binding Duiker1}" Width="*"/>
                                    <DataGridTextColumn Header="Duiker 2" Binding="{Binding Duiker2}" Width="*"/>
                                    <DataGridTextColumn Header="Diepte" Binding="{Binding Diepte}" Width="80"/>
                                    <DataGridTextColumn Header="Totaal sterren" Binding="{Binding TotaalSterren}" Width="110"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="3"
                                       Text="Een team moet samen minstens 5 sterren hebben. Een team van 2 + 2 sterren is enkel toegestaan bij een diepte van maximum 20 meter."
                                       TextWrapping="Wrap"
                                       Foreground="DarkSlateGray"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB: IMPORT / EXPORT -->
            <TabItem Header="Import / Export">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Import en export"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Border Grid.Row="1"
                            Background="White"
                            Padding="20"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Via dit scherm kan u ledengegevens importeren uit een CSV-bestand of exporteren naar een CSV-bestand."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,15"/>

                            <WrapPanel Margin="0,0,0,15">
                                <Button x:Name="btnImporteerCsv"
                                        Content="Importeer CSV"
                                        Width="140"
                                        Margin="0,0,10,0"
                                        Click="btnImporteerCsv_Click"/>
                                <Button x:Name="btnExporteerCsv"
                                        Content="Exporteer CSV"
                                        Width="140"
                                        Click="btnExporteerCsv_Click"/>
                            </WrapPanel>

                            <TextBlock Text="Bestandsinformatie"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,10,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Geselecteerd bestand:"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                <TextBlock x:Name="txtBestandPad"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Laatste actie:"
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                <TextBlock x:Name="txtLaatsteActie"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Status:"
                                           Grid.Row="2"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <TextBlock x:Name="txtStatusImportExport"
                                           Grid.Row="2"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="White"
                            Padding="20"
                            BorderBrush="LightGray"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="CSV-formaat"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Elke regel in het CSV-bestand bevat de gegevens van één lid. De waarden worden gescheiden door komma's."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Voorbeeld:"
                                       FontWeight="Bold"
                                       Margin="0,10,0,5"/>

                            <TextBox Text="Naam,Voornaam,Rijksregisternummer,Straat,Huisnummer,Postcode,Gemeente,Telefoon,Email,Sterren"
                                     IsReadOnly="True"
                                     Margin="0,0,0,5"/>

                            <TextBox Text="Janssens,Tom,12345678901,Kerkstraat,12,9000,Gent,0470123456,tom@example.com,3"
                                     IsReadOnly="True"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>